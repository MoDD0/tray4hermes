# Czech translations for tray4hermes UI strings.
# msgid = English (canonical source language used in the .py code)
# msgstr = Czech translation
#
# Workflow:
#   1. Strings in source code are wrapped in _("English text")
#   2. This file maps English → Czech
#   3. Run scripts/i18n_compile.sh to compile .mo
#   4. At runtime, i18n.install(language='cs') makes _("English") return "Czech"
#
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: cs\n"
"Plural-Forms: nplurals=3; plural=((n==1) ? 0 : (n>=2 && n<=4) ? 1 : 2);\n"

